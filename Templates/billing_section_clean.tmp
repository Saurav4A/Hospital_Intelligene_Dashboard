{% extends "layout.html" %}

{% block title %}Billing Section | HID{% endblock %}

{% block content %}
<style>
  /* --- RESTORED THEMING --- */
  /* Force the background of the body to match the original design */
  body {
    background: 
      radial-gradient(1200px 600px at -10% -10%, #e3f2fd 0, transparent 40%),
      radial-gradient(1400px 700px at 110% -10%, #e3f2fd 0, transparent 35%),
      #f4f7fb !important;
    min-height: 100vh;
    margin: 0;
    font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
    color: #0f172a;
  }

  /* Restoring CSS Variables */
  :root{
    --bg:#f4f7fb; --card:#fff; --ink:#0f172a; --muted:#64748b; --brand:#1e3a8a; --brand-2:#3b82f6; --shadow:0 10px 30px rgba(0,0,0,.08); --radius:16px;
  }

  /* Header Styling */
  .billing-header { text-align:center; margin:70px 0 10px; }
  .billing-header h1 { margin:10px 0 4px; color:var(--brand); font-size:28px; font-weight:800; }
  .billing-header p { margin:0; color:#607d8b; }

  /* Container */
  .billing-container { width:100%; max-width:1200px; margin:20px auto 40px; padding:0 20px; }

  /* View Selector Cards (The top two white cards) */
  .view-selector { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px; margin:30px 0; }
  .view-card { background:#fff; border-radius:18px; padding:20px; box-shadow:0 12px 30px rgba(15,23,42,.08); border:1px solid #e5e9f5; cursor:pointer; transition:transform .18s ease, box-shadow .18s ease; }
  .view-card:hover { transform:translateY(-2px); box-shadow:0 18px 40px rgba(15,23,42,.12); }
  .view-card.active { border-color:#1e3a8a; box-shadow:0 18px 42px rgba(30,58,138,.18); }
  .view-card h3 { margin:0 0 6px; color:#1e3a8a; font-size:18px; }
  .view-card p { margin:0; color:#475569; font-size:13px; }

  /* Dashboard Cards (The lower section cards) */
  .cards-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px; margin:20px 0; }
  .card { background:rgba(255,255,255,.92); border-radius:18px; padding:18px 20px; box-shadow:0 14px 36px rgba(15,23,42,.08); border:1px solid #e2e8f0; }
  .card--actionable { cursor:pointer; transition:transform .18s ease, box-shadow .18s ease; }
  .card--actionable:hover { transform:translateY(-2px); box-shadow:0 18px 40px rgba(15,23,42,.12); }
  .card-head h2 { margin:0; font-size:18px; font-weight:700; color:#1e3a8a; }
  .card-head p { margin:6px 0 0; color:#64748b; font-size:13px; }

  /* KPIs */
  .kpi-grid { margin-top:14px; display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:12px; }
  .kpi { padding:12px 14px; border-radius:14px; border:1px solid #e2e8f0; background:#fff; box-shadow:inset 0 1px 0 rgba(255,255,255,.6); }
  .kpi-label { font-size:9px; text-transform:uppercase; letter-spacing:.4px; color:#94a3b8; font-weight:600; }
  .kpi-value { margin-top:4px; font-size:17px; font-weight:700; color:#0f172a; }
  .kpi-value--accent { color:#0ea5e9; }
  .kpi-empty { padding:12px; color:#94a3b8; font-size:13px; }

  /* Controls / Filters */
  .controls { display:none; gap:10px; flex-wrap:wrap; align-items:flex-end; background:linear-gradient(135deg, rgba(240,244,255,.92), rgba(255,255,255,.96)); padding:16px; border-radius:16px; border:1px solid #dce3f7; box-shadow:0 12px 26px rgba(15,23,42,.08); position:relative; overflow:hidden; }
  .controls::after { content:''; position:absolute; inset:0; background:radial-gradient(circle at 15% 20%, rgba(59,130,246,.12), transparent 45%); pointer-events:none; opacity:.9; }
  .controls.is-visible { display:flex; animation:ribbonSlide .45s cubic-bezier(.23,1,.32,1) both; }
  @keyframes ribbonSlide { 0%{opacity:0;transform:translateY(-14px);} 100%{opacity:1;transform:translateY(0);} }
  .controls label { font-weight:700; font-size:13px; color:var(--ink); }
  .controls input, .controls select { padding:12px 14px; border:1px solid #d7deeb; border-radius:12px; background:#fff; font-size:13px; min-width:180px; }
  .controls button { padding:12px 14px; border:none; border-radius:12px; background:linear-gradient(90deg,var(--brand),var(--brand-2)); color:#fff; font-weight:800; cursor:pointer; box-shadow:0 8px 18px rgba(37,99,235,.22); }

  /* Data Tables */
  .status { margin-top:8px; color:var(--muted); font-size:13px; text-align:right; }
  .table-wrap { margin-top:16px; background:#f8fbff; border-radius:16px; box-shadow:var(--shadow); padding:16px; border:1px solid #edf0f5; overflow-x:auto; }
  table { width:100%; min-width:2200px; border-collapse:collapse; }
  th, td { padding:10px; border-bottom:1px solid #e5e7eb; text-align:left; font-size:13px; vertical-align:top; }
  th { background:#f0f4ff; color:#1e3a8a; font-weight:800; }
  .row-cashless { background:#fde2e4; }

  /* History Groups */
  .hist-group { border:1px solid #e5e7eb; border-radius:12px; margin-bottom:12px; overflow:hidden; background:#fff; box-shadow:0 6px 14px rgba(0,0,0,.06); }
  .hist-head { padding:12px 14px; background:#eef2ff; font-weight:800; display:flex; justify-content:space-between; cursor:pointer; color:#1e3a8a; gap:12px; }
  .hist-body { display:none; background:#fff; overflow-x:auto; }
  .hist-body.open { display:block; }
  .pay-section { margin-bottom:18px; border:1px solid #d7deeb; border-radius:12px; overflow:hidden; background:#f8fbff; }
  .pay-title { font-size:16px; font-weight:800; color:#1e3a8a; margin:0; padding:12px 14px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; background:#eef2ff; }
  
  /* Loading */
  .loading-overlay { display:flex; align-items:center; justify-content:center; gap:12px; padding:26px; color:#1e3a8a; font-weight:700; }
  .spinner { width:26px; height:26px; border:3px solid #cbd5e1; border-top-color:#3b82f6; border-radius:50%; animation:spin .8s linear infinite; }
  @keyframes spin { to{transform:rotate(360deg);} }

  /* FAB / Top Actions (Floating) */
  .top-actions { position:fixed; top:20px; right:20px; z-index:20; display:flex; align-items:flex-end; gap:12px; }
  .fab-user { position:relative; display:flex; align-items:center; gap:10px; }
  .fab-timer { display:inline-flex; align-items:center; justify-content:center; padding:8px 10px; border-radius:12px; background:#0ea5e9; color:#fff; font-weight:700; min-width:72px; box-shadow:0 6px 14px rgba(14,165,233,.25); }
  .fab-btn { width:58px; height:58px; border-radius:50%; background:linear-gradient(135deg, var(--brand), var(--brand-2)); color:#fff; display:grid; place-items:center; font-size:22px; box-shadow:0 8px 20px rgba(37,99,235,.3); border:none; cursor:pointer; transition:transform .18s ease; }
  .fab-btn:hover { transform:scale(1.06); }
  .fab-icon { display:flex; flex-direction:column; gap:5px; align-items:center; }
  .fab-icon span { display:block; width:18px; height:3px; background:#fff; border-radius:2px; }
  .fab-menu { position:absolute; top:60px; right:0; background:rgba(255,255,255,.96); border-radius:12px; box-shadow:var(--shadow); border:1px solid rgba(0,0,0,.06); backdrop-filter:blur(8px); padding:10px; display:none; min-width:220px; }
  .fab-menu.open { display:block; animation:fadeIn .18s ease both; }
  .fab-menu a { display:block; padding:10px 12px; border-radius:10px; color:var(--ink); font-weight:600; text-decoration:none; font-size:14px; }
  .fab-menu a:hover { background:#eef2ff; color:var(--brand); }
  @keyframes fadeIn { from{opacity:0; transform:translateY(-4px);} to{opacity:1; transform:none;} }

  /* Due Tracker specific styles */
  .due-track-card { margin-top:24px; background:#fff; border-radius:24px; box-shadow:0 22px 45px rgba(15,23,42,.12); border:1px solid #e2e8f0; padding:24px; }
  .due-track-head { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:12px; }
  .due-track-head h2 { margin:0; color:#1e3a8a; }
  .due-track-head p { margin:2px 0 0; color:#64748b; }
  .due-type { margin-bottom:18px; padding:14px; border-radius:18px; background:linear-gradient(135deg,#f8fbff,#eef4ff); border:1px solid #e2e8f0; box-shadow:inset 0 1px 0 rgba(255,255,255,.8); }
  .due-type-head { display:flex; justify-content:space-between; align-items:center; font-weight:800; color:#1e3a8a; cursor:pointer; padding:0 6px; }
  .due-type-head span { font-size:12px; color:#475569; font-weight:600; }
  .due-type-body { margin-top:12px; padding-left:8px; border-left:3px solid rgba(30,58,138,.15); }
  .due-type.collapsed .due-type-body { display:none; }
  .due-bill, .due-visit { margin-bottom:12px; border-radius:16px; background:#fff; border:1px solid #e2e8f0; box-shadow:0 12px 24px rgba(15,23,42,.08); overflow:hidden; margin-left:10px; }
  .due-bill-head, .due-visit-head { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; background:#eef2ff; font-weight:700; color:#1e3a8a; cursor:pointer; }
  .due-bill-head span, .due-visit-head span { font-size:12px; color:#475569; font-weight:600; }
  .due-bill-body, .due-visit-body { padding:10px; background:#fdfdff; }
  .due-bill.collapsed .due-bill-body, .due-visit.collapsed .due-visit-body { display:none; }
  .due-sub { margin-bottom:12px; border-radius:14px; background:#fff; border:1px solid #e2e8f0; box-shadow:0 8px 18px rgba(15,23,42,.05); overflow:hidden; margin-left:20px; }
  .due-sub-head { display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:#eef2ff; font-weight:700; color:#1e3a8a; cursor:pointer; }
  .due-sub-head span { font-size:12px; color:#475569; font-weight:600; }
  .due-sub-body { overflow-x:auto; }
  .due-sub.collapsed .due-sub-body { display:none; }
  .due-sub-body table { width:100%; min-width:900px; border-collapse:collapse; }
  .due-sub-body th, .due-sub-body td { padding:8px 10px; border-bottom:1px solid #edf2f7; font-size:12px; text-align:left; }
  .due-sub-body th { background:#f8fafc; color:#1e3a8a; font-weight:700; }
  .due-empty { padding:12px; color:#94a3b8; font-size:13px; text-align:center; }
  .due-cell-alert { background:#fee2e2; color:#991b1b; font-weight:700; }
  .disc-cell-alert { background:#fef3c7; color:#92400e; font-weight:600; }
</style>

<div class="top-actions">
  <div class="fab-user">
    <div class="fab-timer" id="fabTimer">--:--</div>
    <button class="fab-btn" id="fabToggle" title="Menu">
      <span class="fab-icon"><span></span><span></span><span></span></span>
    </button>
    <div class="fab-menu" id="fabMenu">
      <div style="padding:6px 12px;font-weight:700;color:#1e3a8a;">
        ?? {{ session.get('username') or session.get('user') or 'User' }}
      </div>
      <a href="{{ url_for('dashboard') }}">?? Dashboard</a>
      <a href="{{ url_for('mis_dashboard') }}">?? MIS Home</a>
      <a href="{{ url_for('logout') }}">?? Logout</a>
    </div>
  </div>
</div>

<div class="billing-header">
  <h1>Billing, Collections & Financial KPIs</h1>
  <p>Discharge-wise bills grouped by patient</p>
</div>

<div class="view-selector" style="max-width:1200px; margin: 30px auto; padding: 0 20px;">
  <div class="view-card" data-view="ipd">
    <h3>In-Patient Discharges</h3>
    <p>Monitor discharge-wise bills, collections, and outstanding.</p>
  </div>
  <div class="view-card" data-view="due">
    <h3>Out-Patient Due &amp; Discounts</h3>
    <p>Track discounts and dues grouped by visit type and patient categories.</p>
  </div>
  <div class="view-card" data-view="collections">
    <h3>Collections (Receipts)</h3>
    <p>Receipt summary by payment mode &amp; category.</p>
  </div>
  <div class="view-card" data-view="compliance">
    <h3>Billing-Collection Compliance</h3>
    <p>Match receipts against billed revenue and flag suspense.</p>
  </div>
</div>

<div class="billing-container">
  <section id="ipdView" class="view-panel">
    <div class="cards-grid">
      <section class="card card--actionable" data-card="billing">
        <div class="card-head">
          <h2>Billing, Collection &amp; Financial KPIs</h2>
          <p>Real-time discharge billing data grouped by pay type.</p>
        </div>
        <div class="kpi-grid" id="kpiBilling">
          <div class="kpi-empty">Select a unit and load data.</div>
        </div>
      </section>
      <section class="card">
        <div class="card-head">
          <h2>Due, Discount, Write-offs</h2>
          <p>Monitor dues, concessions, and write-back trends.</p>
        </div>
        <div class="kpi-grid" id="kpiDue">
          <div class="kpi-empty">Select a unit and load data.</div>
        </div>
      </section>
    </div>
    
    <div class="controls" id="billFilters">
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>From</label>
        <input type="date" id="billFrom">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>To</label>
        <input type="date" id="billTo">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>Unit</label>
        <select id="billUnit">
          {% for u in allowed_units %}
            <option value="{{ u }}">{{ u }}</option>
          {% endfor %}
        </select>
      </div>
      <div Style="display:flex; flex-direction:column; gap:6px;">
        <label>Search (Reg/Name/Bill/PT-Type/PT-SubType)</label>
        <input type="text" id="billSearch" placeholder="Search…">
      </div>
      <div>
        <button id="billLoad">Load</button>
      </div>
      <div>
        <button id="billExportXlsx">Export XLSX</button>
        <button id="billExportPdf" style="margin-left:6px; background-color: #28a745; color: white; border-color: #28a745;">Export PDF</button>
      </div>
    </div>
    
    <div class="status" id="billStatus"></div>
    <div class="table-wrap" id="billTable"></div>
  </section>

  <section id="dueView" class="view-panel" style="display:none;">
    <div class="controls controls-due" id="dueFilters">
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>From</label>
        <input type="date" id="dueFrom">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>To</label>
        <input type="date" id="dueTo">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>Unit</label>
        <select id="dueUnit">
          {% for u in allowed_units %}
            <option value="{{ u }}">{{ u }}</option>
          {% endfor %}
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>Search (any field)</label>
        <input type="text" id="dueSearch" placeholder="Search discount/due records">
      </div>
      <div>
        <button id="dueLoad">Load Due &amp; Discounts</button>
        <button id="dueExportXlsx" style="margin-left:8px;">Export XLSX</button>
        <button id="dueExportPdf" style="margin-left:8px;">Export PDF</button>
      </div>
    </div>
    <div class="due-track-card">
      <div class="due-track-head">
        <div>
          <h2>Discount &amp; Outstanding Tracker</h2>
          <p>Grouped by visit type and patient type</p>
        </div>
      </div>
      <div class="due-track-body" id="dueTrackContent">
        <div class="due-empty">Select filters and load due &amp; discount data.</div>
      </div>
    </div>
  </section>

  <section id="collectionsView" class="view-panel" style="display:none;">
    <div class="controls" id="collFilters">
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>From</label>
        <input type="date" id="collFrom">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>To</label>
        <input type="date" id="collTo">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>Unit</label>
        <select id="collUnit">
          {% for u in allowed_units %}
            <option value="{{ u }}">{{ u }}</option>
          {% endfor %}
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:6px; min-width:240px;">
        <label>Search Receipts</label>
        <input type="text" id="collSearch" placeholder="Search amount, receipt no, visit no, patient, mode, user">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px; min-width:200px;">
        <label>Receipt Type</label>
        <select id="collReceiptType">
          <option value="all">All</option>
          <option value="hospital">Hospital Receipts</option>
          <option value="op_pharmacy">OP Pharmacy</option>
          <option value="ip_pharmacy">IP Pharmacy</option>
        </select>
      </div>
      <div>
        <button id="collLoad">Load Collections</button>
        <button id="collExportXlsx" style="margin-left:8px;">Export XLSX</button>
      </div>
    </div>
    <div class="cards-grid" style="margin-top:20px;">
      <section class="card card--actionable">
        <div class="card-head">
          <h2>Collections (Receipts)</h2>
          <p>Receipt summary by payment mode &amp; category.</p>
        </div>
        <div class="kpi-grid" id="kpiCollections">
          <div class="kpi-empty">Select a unit and load data.</div>
        </div>
      </section>
    </div>
    <div class="status" id="collStatus" style="margin-top:12px;"></div>
    <div class="table-wrap" id="collTable"></div>
  </section>

  <section id="complianceView" class="view-panel" style="display:none;">
    <div class="controls" id="compFilters">
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>From</label>
        <input type="date" id="compFrom">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>To</label>
        <input type="date" id="compTo">
      </div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <label>Unit</label>
        <select id="compUnit">
          {% for u in allowed_units %}
            <option value="{{ u }}">{{ u }}</option>
          {% endfor %}
        </select>
      </div>
      <div>
        <button id="compLoad">Load Compliance</button>
      </div>
    </div>
    <div class="cards-grid" style="margin-top:20px; max-width:1200px; margin-left:auto; margin-right:auto;">
      <section class="card card--actionable">
        <div class="card-head">
          <h2>Compliance (Receipts vs Bills)</h2>
          <p>Primary: Receipts · Secondary: Revenue</p>
        </div>
        <div class="kpi-grid" id="compKpi">
          <div class="kpi-empty">Load to view mismatches.</div>
        </div>
      </section>
    </div>
    <div class="status" id="compStatus" style="margin-top:12px;"></div>
    <div class="table-wrap" id="compTable" style="max-width:1200px; margin-left:auto; margin-right:auto;"></div>
  </section>
</div>
{% endblock %}

{% block scripts %}
  <script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.8.2/dist/jspdf.plugin.autotable.min.js"></script>
  <script>
    (function(){
      const controlsWrap = document.getElementById('billFilters');
      const unitSel = document.getElementById('billUnit');
      const fromEl = document.getElementById('billFrom');
      const toEl = document.getElementById('billTo');
      const searchEl = document.getElementById('billSearch');
      const loadBtn = document.getElementById('billLoad');
      const tableWrap = document.getElementById('billTable');
      const statusEl = document.getElementById('billStatus');
      const collStatus = document.getElementById('collStatus');
      const collTable = document.getElementById('collTable');
      const kpiBilling = document.getElementById('kpiBilling');
      const kpiDue = document.getElementById('kpiDue');
      const kpiCollections = document.getElementById('kpiCollections');
      const dueTrackWrap = document.getElementById('dueTrackContent');
      const dueFiltersWrap = document.getElementById('dueFilters');
      const billingCard = document.querySelector('[data-card="billing"]');
      const ipdView = document.getElementById('ipdView');
      const dueView = document.getElementById('dueView');
      const collView = document.getElementById('collectionsView');
      const viewCards = document.querySelectorAll('.view-card');
      const dueFromEl = document.getElementById('dueFrom');
      const dueToEl = document.getElementById('dueTo');
      const dueUnitSel = document.getElementById('dueUnit');
      const dueSearchEl = document.getElementById('dueSearch');
      const dueLoadBtn = document.getElementById('dueLoad');
      const dueExportXlsxBtn = document.getElementById('dueExportXlsx');
      const dueExportPdfBtn = document.getElementById('dueExportPdf');
      const collFromEl = document.getElementById('collFrom');
      const collToEl = document.getElementById('collTo');
      const collUnitSel = document.getElementById('collUnit');
      const collLoadBtn = document.getElementById('collLoad');
      const collExportBtn = document.getElementById('collExportXlsx');
      const collSearchEl = document.getElementById('collSearch');
      const collReceiptTypeSel = document.getElementById('collReceiptType');
      const compFromEl = document.getElementById('compFrom');
      const compToEl = document.getElementById('compTo');
      const compUnitSel = document.getElementById('compUnit');
      const compLoadBtn = document.getElementById('compLoad');
      const compStatus = document.getElementById('compStatus');
      const compTable = document.getElementById('compTable');
      const compKpi = document.getElementById('compKpi');
      const today = new Date().toISOString().slice(0,10);
      const fabToggle = document.getElementById('fabToggle');
      const fabMenu = document.getElementById('fabMenu');
      const fabTimer = document.getElementById('fabTimer');
      const exportBtn = document.getElementById('billExportXlsx');
      const exportPdfBtn = document.getElementById('billExportPdf');
      let collData = [];
      let collFiltered = [];
      let collPage = 1;
      const collPageSize = 20;
      const amountFields = new Set(['GrossAmount','DiscountAmount','NetAmount','LabTotal','RadioTotal','HospitalTotal','PhBill','IPDRecp','PHRet','DueAmount']);
      const loadingHtml = '<div class="loading-overlay"><div class="spinner"></div><div>Fetching data, please wait.</div></div>';
      const fmt2 = (v)=>{ const n = Number(v); return Number.isFinite(n) ? n.toFixed(2) : (v ?? ''); };
      const payLabel = (row)=>{
        const raw = row?.paytype ?? row?.PayType ?? '';
        if(String(raw) === '1') return 'Cash';
        if(String(raw) === '2') return 'Cashless';
        return 'Other';
      };
      const cleanText = (v)=> (v === null || v === undefined) ? '' : String(v).trim();
      const fmtDateCell = (value)=>{
        if(!value) return '';
        if(value instanceof Date && !isNaN(value)) return value.toLocaleDateString('en-GB');
        const str = String(value).trim();
        const isoMatch = str.match(/^(\d{4})-(\d{2})-(\d{2})/);
        if(isoMatch){
          return `${isoMatch[3]}-${isoMatch[2]}-${isoMatch[1]}`;
        }
        const human = new Date(str);
        if(!isNaN(human)) return human.toLocaleDateString('en-GB');
        return str.replace(/T.*/, '');
      };
      const fmtNumberCell = (value)=>{
        if(value === null || value === undefined || value === '') return '';
        const num = Number(String(value).replace(/,/g,'')); 
        return Number.isFinite(num) ? num.toFixed(2) : String(value);
      };
      const parseNumber = (value)=>{
        if(value === null || value === undefined || value === '') return 0;
        const num = Number(String(value).replace(/,/g,''));
        return Number.isFinite(num) ? num : 0;
      };
      const mergeStyles = (orig = {}, extra = {})=>{
        const out = { ...orig };
        Object.entries(extra).forEach(([k,v])=>{
          if(v && typeof v === 'object' && !Array.isArray(v)){
            out[k] = mergeStyles(out[k] || {}, v);
          }else{
            out[k] = v;
          }
        });
        return out;
      };
      const applyCellStyle = (sheet, cellRef, style)=>{
        if(!sheet[cellRef]) return;
        sheet[cellRef].s = mergeStyles(sheet[cellRef].s || {}, style);
      };
      const formatINR = (value)=> new Intl.NumberFormat('en-IN',{style:'currency',currency:'INR',maximumFractionDigits:2}).format(value||0);
      const formatPercent = (value)=> `${(value||0).toFixed(1)}%`;
      const renderKpiBox = (label,value,type)=>{
        const display = type==='percent'?formatPercent(value):formatINR(value);
        const accent = type==='percent'?' kpi-value--accent':'';
        return `<div class="kpi"><div class="kpi-label">${label}</div><div class="kpi-value${accent}">${display}</div></div>`;
      };

      function renderCollections(){
        if(!kpiCollections || !collTable) return;
        if(!collFiltered || !collFiltered.length){
          kpiCollections.innerHTML = '<div class="kpi-empty">No collections data for this range.</div>';
          collTable.innerHTML = '<div class="kpi-empty">No collections records.</div>';
          return;
        }
        const rupee = (v)=> formatINR(v);
        const isCashlessRow = (row)=>{
          const pay = cleanText(row.PayType || row.paytype || row.PatientCategory).toLowerCase();
          const mode = cleanText(row.PModeName).toLowerCase();
          return (pay.includes('cashless') || pay==='2') && mode !== 'debit voucher';
        };
        const totalAmt = collFiltered.reduce((s,r)=> s + parseNumber(r.Amount), 0);
        const advAmt = collFiltered.reduce((s,r)=> s + (cleanText(r.ReceiptCategory).toLowerCase()==='advance receipts' ? parseNumber(r.Amount) : 0), 0);
        const billAmt = Math.max(0, totalAmt - advAmt);
        const uniquePatients = new Set(collFiltered.map(r => cleanText(r.RegNo || r.Regno || r.PatientID || r.Patient_Id || r.Patient_ID))).size;
        const modeTotals = {};
        collFiltered.forEach(r=>{
          const m = cleanText(r.PModeName) || 'Unknown';
          modeTotals[m] = (modeTotals[m] || 0) + parseNumber(r.Amount);
        });
        const modeHtml = Object.entries(modeTotals).sort((a,b)=>b[1]-a[1]).map(([m,v])=>`<div class="kpi"><div class="kpi-label">${m}</div><div class="kpi-value">${formatINR(v)}</div></div>`).join('');

        // Segregations
        const rtypeTotals = { PH:0, P:0, PI:0, Other:0 };
        const rcatTotals = { "Advance Receipts":0, "Receipt Against Bill":0, Other:0 };
        const ptypeTotals = {};
        collFiltered.forEach(r=>{
          const rt = cleanText(r.ReceiptType).toUpperCase();
          if(rt === 'PH') rtypeTotals.PH += parseNumber(r.Amount);
          else if(rt === 'P') rtypeTotals.P += parseNumber(r.Amount);
          else if(rt === 'PI') rtypeTotals.PI += parseNumber(r.Amount);
          else rtypeTotals.Other += parseNumber(r.Amount);

          const rc = cleanText(r.ReceiptCategory) || 'Other';
          if(rc.toLowerCase() === 'advance receipts') rcatTotals["Advance Receipts"] += parseNumber(r.Amount);
          else if(rc.toLowerCase() === 'receipt against bill') rcatTotals["Receipt Against Bill"] += parseNumber(r.Amount);
          else rcatTotals.Other += parseNumber(r.Amount);

          const pt = cleanText(r.PatientTypes || r.PatientType || r.Patient_Types || '');
          if(pt) ptypeTotals[pt] = (ptypeTotals[pt] || 0) + parseNumber(r.Amount);
        });

        kpiCollections.innerHTML = `
          ${renderKpiBox('Total Collections', totalAmt)}
          ${renderKpiBox('Advance Receipts', advAmt)}
          ${renderKpiBox('Against Bills', billAmt)}
          <div class="kpi"><div class="kpi-label">Receipts</div><div class="kpi-value">${collFiltered.length.toLocaleString('en-IN')}</div><div class="kpi-label" style="margin-top:6px;">Unique Patients</div><div class="kpi-value kpi-value--accent">${uniquePatients.toLocaleString('en-IN')}</div></div>
          ${modeHtml}
        `;

        const receiptTypeLabel = { PH:'OP Pharmacy', PI:'IP Pharmacy', P:'Hospital Receipts', Other:'Other' };
        const receiptTypeHtml = Object.entries(rtypeTotals).map(([k,v])=>`<div style="padding:6px 8px;">${receiptTypeLabel[k] || k}: <strong>${rupee(v)}</strong></div>`).join('');
        const categoryHtml = Object.entries(rcatTotals).map(([k,v])=>`<div style="padding:6px 8px;">${k}: <strong>${rupee(v)}</strong></div>`).join('');
        const ptypeHtml = Object.entries(ptypeTotals).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`<div style="padding:6px 8px;">${k}: <strong>${rupee(v)}</strong></div>`).join('');
        // Visit-wise totals with receipt-type breakup
        const visitMap = {};
        collFiltered.forEach(r=>{
          const visit = cleanText(r.TypeOfVisit) || 'Unknown Visit';
          const rtRaw = cleanText(r.ReceiptType).toUpperCase();
          const rtKey = rtRaw === 'PH' ? 'PH' : rtRaw === 'PI' ? 'PI' : rtRaw === 'P' ? 'P' : 'Other';
          const amt = parseNumber(r.Amount);
          if(!visitMap[visit]) visitMap[visit] = { total:0, receipts:{PH:0,PI:0,P:0,Other:0} };
          visitMap[visit].total += amt;
          visitMap[visit].receipts[rtKey] += amt;
        });
        const visitBreakupHtml = Object.entries(visitMap).sort((a,b)=>b[1].total - a[1].total).map(([visit,data])=>{
          const recHtml = Object.entries(data.receipts).filter(([,v])=>v>0).map(([k,v])=>`${receiptTypeLabel[k] || k}: <strong>${rupee(v)}</strong>`).join(' · ') || 'No receipts';
          return `<div style="padding:6px 8px; min-width:220px;">
            <div>${visit}: <strong>${rupee(data.total)}</strong></div>
            <div style="font-size:12px; color:#475569; margin-top:4px;">${recHtml}</div>
          </div>`;
        }).join('') || '<div style="padding:6px 8px;">No data</div>';

        // Top collectors
        const collectorTotals = {};
        collFiltered.forEach(r=>{
          const u = cleanText(r.UserName || r.User);
          if(u) collectorTotals[u] = (collectorTotals[u] || 0) + parseNumber(r.Amount);
        });
        const topCollectors = Object.entries(collectorTotals).sort((a,b)=>b[1]-a[1]).slice(0,3);
        const collectorsHtml = topCollectors.map(([u,v])=>`<div style="padding:6px 8px;">${u}: <strong>${rupee(v)}</strong></div>`).join('') || '<div style="padding:6px 8px;">No data</div>';

        const totalPages = Math.max(1, Math.ceil(collFiltered.length / collPageSize));
        if(collPage > totalPages) collPage = totalPages;
        const startIdx = (collPage - 1) * collPageSize;
        const rowsSlice = collFiltered.slice(startIdx, startIdx + collPageSize);

        const rows = rowsSlice.map(r=>{
          const reg = cleanText(r.RegNo || r.Regno || r.PatientID || r.PatientId);
          const pat = cleanText(r.Patientname || r.Patient || r.PatientName);
          const bill = cleanText(r.BillNo);
          const rec = cleanText(r.Receipt_No);
          const recCat = cleanText(r.ReceiptCategory);
          const recType = cleanText(r.ReceiptType);
          const payMode = cleanText(r.PModeName);
          const visit = cleanText(r.TypeOfVisit);
          const user = cleanText(r.UserName);
          const payee = cleanText(r.PayeeId);
          const billDate = fmtDateCell(r.BillDate);
          const billNet = fmtNumberCell(r.NetAmount || r.BILLING_MST_NETAMOUNT || r.NETAMOUNT);
          const tov = cleanText(r.TypeOfVisit);
          const rowClasses = [];
          if(isCashlessRow(r)) rowClasses.push('row-cashless');
          return `
            <tr class="${rowClasses.join(' ')}">
              <td>${rec}</td>
              <td>${fmtDateCell(r.Receipt_Date)}</td>
              <td>${cleanText(r.Receipt_Time)}</td>
              <td>${recCat}</td>
              <td>${recType}</td>
              <td>${payMode}</td>
              <td>${rupee(parseNumber(r.Amount))}</td>
              <td>${bill}</td>
              <td>${billDate}</td>
              <td>${billNet}</td>
              <td>${pat}</td>
              <td>${reg}</td>
              <td>${cleanText(r.VisitNo)}</td>
              <td>${cleanText(r.PatientTypes || r.PatientType)}</td>
              <td>${tov}</td>
              <td>${cleanText(r.Admission_Dt)}</td>
              <td>${user}</td>
              <td>${payee}</td>
            </tr>
          `;
        }).join('');
        collTable.innerHTML = `
          <div class="cards-grid" style="margin-bottom:10px;">
            <section class="card">
              <div class="card-head"><h2>Receipt Type</h2><p>PH=OP Pharm, P=Hospital, PI=IP Pharm</p></div>
              <div style="display:flex; flex-wrap:wrap;">${receiptTypeHtml}</div>
            </section>
            <section class="card">
              <div class="card-head"><h2>Category</h2><p>Advance vs Against Bill</p></div>
              <div style="display:flex; flex-wrap:wrap;">${categoryHtml}</div>
            </section>
            <section class="card">
              <div class="card-head"><h2>Patient Type</h2><p>Amount by Patient Type</p></div>
              <div style="display:flex; flex-wrap:wrap;">${ptypeHtml || '<div style="padding:6px 8px;">No data</div>'}</div>
            </section>
            <section class="card">
              <div class="card-head"><h2>Type of Visit</h2><p>Amount by Visit Type</p></div>
              <div style="display:flex; flex-wrap:wrap;">${visitBreakupHtml}</div>
            </section>
            <section class="card">
              <div class="card-head"><h2>Top Collectors</h2><p>Highest receipt amounts</p></div>
              <div style="display:flex; flex-wrap:wrap;">${collectorsHtml}</div>
            </section>
          </div>
          <div class="table-wrap-inner" style="overflow-x:auto;">
            <table style="min-width:1400px;">
              <thead>
                <tr>
                  <th>Receipt No</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Category</th>
                  <th>Type</th>
                  <th>Payment Mode</th>
                  <th>Amount</th>
                  <th>Bill No</th>
                  <th>Bill Date</th>
                  <th>Bill Net Amount</th>
                  <th>Patient</th>
                  <th>Reg No</th>
                  <th>Visit No</th>
                  <th>Patient Type</th>
                  <th>Visit</th>
                  <th>Admission Date</th>
                  <th>User</th>
                  <th>Payee</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:10px;">
            <div>Showing ${rowsSlice.length ? startIdx + 1 : 0}-${Math.min(startIdx + rowsSlice.length, collFiltered.length)} of ${collFiltered.length}</div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button id="collPrev" ${collPage<=1?'disabled':''}>Prev</button>
              <span>Page ${collPage} / ${totalPages}</span>
              <button id="collNext" ${collPage>=totalPages?'disabled':''}>Next</button>
            </div>
          </div>
        `;
        const prevBtn = document.getElementById('collPrev');
        const nextBtn = document.getElementById('collNext');
        prevBtn?.addEventListener('click', ()=>{ if(collPage>1){ collPage--; renderCollections(); }});
        nextBtn?.addEventListener('click', ()=>{ if(collPage<totalPages){ collPage++; renderCollections(); }});
      }
      function applyCollSearch(){
        const q = (collSearchEl?.value || '').trim().toLowerCase();
        const typeFilter = (collReceiptTypeSel?.value || 'all').toLowerCase();
        let working = [...collData];

        if(typeFilter !== 'all'){
          working = working.filter(r=>{
            const rt = cleanText(r.ReceiptType).toUpperCase();
            if(typeFilter === 'hospital') return rt === 'P';
            if(typeFilter === 'op_pharmacy') return rt === 'PH';
            if(typeFilter === 'ip_pharmacy') return rt === 'PI';
            return true;
          });
        }

        if(q){
          const fields = [
            'Amount','Receipt_No','VisitNo','Receipt_Time','Receipt_Date',
            'PModeName','BillDate','UserName','PatientTypes','PatientType','Patient','PatientName','Patientname'
          ];
          working = working.filter(r=>{
            return fields.some(f=>{
              const v = r[f];
              if(v === null || v === undefined) return false;
              return String(v).toLowerCase().includes(q);
            });
          });
        }

        collFiltered = working;
        collPage = 1;
        renderCollections();
      }
      function renderDueTrackView(rows){
        if(!dueTrackWrap) return;
        if(!rows || !rows.length){
          dueTrackWrap.innerHTML = '<div class="due-empty">No discount/due records for this range.</div>';
          return;
        }
        const grouped = {};
        rows.forEach(row=>{
          const pay = cleanText(row.PatientCategory) || 'PayType - Unknown';
          const bill = cleanText(row.BillCategory) || 'Bill Category - Unknown';
          const visit = cleanText(row.TypeOfVisit) || 'Visit Type - Unknown';
          const pat = cleanText(row.PatType) || 'Patient Type - Unknown';
          grouped[pay] = grouped[pay] || {};
          grouped[pay][bill] = grouped[pay][bill] || {};
          grouped[pay][bill][visit] = grouped[pay][bill][visit] || {};
          grouped[pay][bill][visit][pat] = grouped[pay][bill][visit][pat] || [];
          grouped[pay][bill][visit][pat].push(row);
        });
        let html = '';
        Object.entries(grouped).forEach(([payType, billGroups])=>{
          const payRows = Object.values(billGroups).flatMap(v=>Object.values(v).flatMap(p=>Object.values(p).flat()));
          const payTotals = payRows.reduce((acc,row)=>{
            acc.gross += parseNumber(row.GrossAmount);
            acc.discount += parseNumber(row.DiscountAmount);
            acc.due += parseNumber(row.DueAmount);
            return acc;
          },{gross:0,discount:0,due:0});
          html += `<div class="due-type collapsed">
            <div class="due-type-head" data-type-toggle>
              <span>${payType}</span>
              <span>Gross ${formatINR(payTotals.gross)} · Discount ${formatINR(payTotals.discount)} · Due ${formatINR(payTotals.due)}</span>
            </div>
            <div class="due-type-body">`;
          Object.entries(billGroups).forEach(([billCat, visitGroups])=>{
            const billRows = Object.values(visitGroups).flatMap(p=>Object.values(p).flat());
            const billTotals = billRows.reduce((acc,row)=>{
              acc.gross += parseNumber(row.GrossAmount);
              acc.discount += parseNumber(row.DiscountAmount);
              acc.due += parseNumber(row.DueAmount);
              return acc;
            },{gross:0,discount:0,due:0});
            html += `<div class="due-bill collapsed">
              <div class="due-bill-head" data-bill-toggle>
                <span>${billCat}</span>
                <span>Gross ${formatINR(billTotals.gross)} · Discount ${formatINR(billTotals.discount)} · Due ${formatINR(billTotals.due)}</span>
              </div>
              <div class="due-bill-body">`;
            Object.entries(visitGroups).forEach(([visit, patGroups])=>{
              const visitRows = Object.values(patGroups).flat();
              const visitTotals = visitRows.reduce((acc,row)=>{
                acc.gross += parseNumber(row.GrossAmount);
                acc.discount += parseNumber(row.DiscountAmount);
                acc.due += parseNumber(row.DueAmount);
                return acc;
              },{gross:0,discount:0,due:0});
              html += `<div class="due-visit collapsed">
                <div class="due-visit-head" data-visit-toggle>
                  <span>${visit}</span>
                  <span>Gross ${formatINR(visitTotals.gross)} · Discount ${formatINR(visitTotals.discount)} · Due ${formatINR(visitTotals.due)}</span>
                </div>
                <div class="due-visit-body">`;
              Object.entries(patGroups).forEach(([pat, patRows])=>{
                const totals = patRows.reduce((acc,row)=>{
                  acc.gross += parseNumber(row.GrossAmount);
                  acc.discount += parseNumber(row.DiscountAmount);
                  acc.due += parseNumber(row.DueAmount);
                  acc.net += parseNumber(row.NetAmount);
                  return acc;
                },{gross:0,discount:0,due:0,net:0});
                html += `
                  <div class="due-sub collapsed">
                    <div class="due-sub-head" data-sub-toggle>
                      <span>${pat}</span>
                      <span>Gross ${formatINR(totals.gross)} · Discount ${formatINR(totals.discount)} · Due ${formatINR(totals.due)}</span>
                    </div>
                    <div class="due-sub-body">
                  <table>
                    <thead>
                      <tr>
                        <th>Reg No</th>
                        <th>Patient</th>
                        <th>Visit No</th>
                        <th>Bill No</th>
                        <th>Bill Date</th>
                        <th>Bill Cat</th>
                        <th>Patient Cat</th>
                        <th>Gross</th>
                        <th>Discount</th>
                        <th>Net</th>
                        <th>Due</th>
                        <th>Department</th>
                        <th>User</th>
                      </tr>
                    </thead>
                    <tbody>
                      ${patRows.map(row=>{
                        const dueVal = parseNumber(row.DueAmount);
                        const discVal = parseNumber(row.DiscountAmount);
                        const dueCls = dueVal > 0 ? 'due-cell-alert' : '';
                        const discCls = discVal > 0 ? 'disc-cell-alert' : '';
                        return `
                        <tr>
                          <td>${cleanText(row.Regno)}</td>
                          <td>${cleanText(row.Patient_Name)}</td>
                          <td>${cleanText(row.VisitNo)}</td>
                          <td>${cleanText(row.BillNo)}</td>
                          <td>${cleanText(row.BillDate).replace(/ GMT.*/, '')}</td>
                          <td>${cleanText(row.BillCategory)}</td>
                          <td>${cleanText(row.PatientCategory)}</td>
                          <td>${formatINR(row.GrossAmount)}</td>
                          <td class="${discCls}">${formatINR(row.DiscountAmount)}</td>
                          <td>${formatINR(row.NetAmount)}</td>
                          <td class="${dueCls}">${formatINR(dueVal)}</td>
                          <td>${cleanText(row.Department)}</td>
                          <td>${cleanText(row.Username)}</td>
                        </tr>`;
                      }).join('')}
                    </tbody>
                  </table>
                </div>
              </div>`;
              });
              html += '</div></div>';
            });
            html += '</div></div>';
          });
          html += '</div></div>';
        });
        dueTrackWrap.innerHTML = html;
        dueTrackWrap.querySelectorAll('[data-type-toggle]').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            btn.closest('.due-type')?.classList.toggle('collapsed');
          });
        });
        dueTrackWrap.querySelectorAll('[data-bill-toggle]').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            btn.closest('.due-bill')?.classList.toggle('collapsed');
          });
        });
        dueTrackWrap.querySelectorAll('[data-visit-toggle]').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            btn.closest('.due-visit')?.classList.toggle('collapsed');
          });
        });
        dueTrackWrap.querySelectorAll('[data-sub-toggle]').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            btn.closest('.due-sub')?.classList.toggle('collapsed');
          });
        });
      }
      async function fetchDiscountDue(unit, from, to){
        if(!dueTrackWrap) return;
        dueTrackWrap.innerHTML = '<div class="due-empty">Loading discount/due records…</div>';
        try{
          const res = await fetch(`/api/mis/discount_due_track?unit=${encodeURIComponent(unit)}&from=${from}&to=${to}`);
          const data = await res.json();
          if(!res.ok || data.status !== 'success'){
            throw new Error(data.message || 'Failed to load discount/due track');
          }
          dueData = data.data || [];
          applyDueSearch();
        }catch(err){
          dueData = [];
          dueTrackWrap.innerHTML = `<div class="due-empty">Error loading discount/due track: ${err.message}</div>`;
        }
      }
      function exportDueXlsx(){
        const rows = (dueFiltered && dueFiltered.length) ? dueFiltered : dueData;
        if(!rows || !rows.length){
          alert('No due/discount data to export.');
          return;
        }

        const getDuePayType = (row) => {
            const patientCategory = (row.PatientCategory || '').toLowerCase();
            if (patientCategory.includes('cashless') || patientCategory.includes('corporate') || patientCategory.includes('tpa') || patientCategory.includes('insurance') || patientCategory.includes('credit') || patientCategory.includes('panel')) {
                return 'Cashless';
            }
            if (patientCategory.includes('cash')) {
                return 'Cash';
            }
            const patType = (row.PatType || '').toLowerCase();
            if (patType.includes('cashless') || patType.includes('corporate') || patType.includes('tpa') || patType.includes('insurance') || patType.includes('credit') || patType.includes('panel')) {
                return 'Cashless';
            }
            if (patType.includes('cash')) {
                return 'Cash';
            }
            return 'Cash'; // Default to cash
        };

        const cashRows = rows.filter(row => getDuePayType(row) === 'Cash');
        const cashlessRows = rows.filter(row => getDuePayType(row) === 'Cashless');

        const mapRows = (r) => ({
            'Pay Type': cleanText(r.PatientCategory),
            'Bill Category': cleanText(r.BillCategory),
            'Visit Type': cleanText(r.TypeOfVisit),
            'Patient Type': cleanText(r.PatType),
            'Reg No': cleanText(r.Regno),
            'Patient': cleanText(r.Patient_Name),
            'Visit No': cleanText(r.VisitNo),
            'Bill No': cleanText(r.BillNo),
            'Bill Date': cleanText(r.BillDate),
            'Gross Amount': parseNumber(r.GrossAmount),
            'Discount Amount': parseNumber(r.DiscountAmount),
            'Net Amount': parseNumber(r.NetAmount),
            'Due Amount': parseNumber(r.DueAmount),
            'Department': cleanText(r.Department),
            'User': cleanText(r.Username)
        });

        const wb = XLSX.utils.book_new();
        let added = 0;

        const headerStyle = {
            font: { bold: true, color: { rgb: "FFFFFFFF" } },
            fill: { patternType: "solid", fgColor: { rgb: "FF1E3A8A" } },
            alignment: { horizontal: "center", vertical: "center" }
        };

        const processSheet = (sheet, data) => {
            if (!sheet) return;
            // Freeze pane
            sheet['!freeze'] = { ySplit: 1 };
            
            // Style header
            const range = XLSX.utils.decode_range(sheet['!ref']);
            for (let C = range.s.c; C <= range.e.c; ++C) {
                const addr = XLSX.utils.encode_cell({ r: 0, c: C });
                if (sheet[addr]) {
                    sheet[addr].s = headerStyle;
                }
            }
            
            // Auto-fit columns
            if (data && data.length > 0) {
                const colWidths = Object.keys(data[0]).map(key => {
                    const maxLength = Math.max(
                        key.length,
                        ...data.map(row => (row[key] || '').toString().length)
                    );
                    return { wch: maxLength + 2 };
                });
                sheet['!cols'] = colWidths;
            }
        };

        if (cashRows.length > 0) {
            const cashExport = cashRows.map(mapRows);
            const wsCash = XLSX.utils.json_to_sheet(cashExport);
            processSheet(wsCash, cashExport);
            XLSX.utils.book_append_sheet(wb, wsCash, 'Cash');
            added++;
        }

        if (cashlessRows.length > 0) {
            const cashlessExport = cashlessRows.map(mapRows);
            const wsCashless = XLSX.utils.json_to_sheet(cashlessExport);
            processSheet(wsCashless, cashlessExport);
            XLSX.utils.book_append_sheet(wb, wsCashless, 'Cashless');
            added++;
        }

        if (!added) {
            alert('No Cash or Cashless records to export.');
            return;
        }

        const stamp = new Date().toISOString().slice(0,10);
        XLSX.writeFile(wb, `Due_Discount_${stamp}.xlsx`);
      }
      function exportDuePdf() {
        const rows = (dueFiltered && dueFiltered.length) ? dueFiltered : dueData;
        if (!rows || !rows.length) {
            alert('No due/discount data to export.');
            return;
        }

        const createPdf = (logoDataURL, logoWidth, logoHeight) => {
            const jsPDF = window.jspdf.jsPDF;
            const doc = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });

            const fromDate = dueFromEl.value || today;
            const toDate = dueToEl.value || today;
            const dateRange = `Date Range: ${fromDate} to ${toDate}`;
            const exportedBy = `Exported By: {{ session.get('username') or session.get('user') or 'User' }}`;
            const printInfo = `Printed: ${new Date().toLocaleString()}`;

            let textStartX = 40;
            if (logoDataURL && logoWidth && logoHeight) {
                const maxWidth = 80;
                const maxHeight = 40;
                const logoAspectRatio = logoWidth / logoHeight;
                
                let displayWidth = maxWidth;
                let displayHeight = displayWidth / logoAspectRatio;

                if (displayHeight > maxHeight) {
                    displayHeight = maxHeight;
                    displayWidth = displayHeight * logoAspectRatio;
                }

                doc.addImage(logoDataURL, 'PNG', 40, 20, displayWidth, displayHeight);
                textStartX = 40 + displayWidth + 10;
            }
            
            doc.setFontSize(16);
            doc.text('Asarfi Hospital - Due & Discounts', textStartX, 35);
            doc.setFontSize(10);
            doc.text(dateRange, textStartX, 50);
            doc.text(exportedBy, textStartX, 65);


            const rightAlignX = doc.internal.pageSize.getWidth() - 40;
            doc.text(printInfo, rightAlignX, 35, { align: 'right' });

            const cols = [
                { header: 'Pay Type', dataKey: 'PatientCategory' },
                { header: 'Bill Cat', dataKey: 'BillCategory' },
                { header: 'Visit Type', dataKey: 'TypeOfVisit' },
                { header: 'Patient Type', dataKey: 'PatType' },
                { header: 'Reg No', dataKey: 'Regno' },
                { header: 'Patient', dataKey: 'Patient_Name' },
                { header: 'Visit No', dataKey: 'VisitNo' },
                { header: 'Bill No', dataKey: 'BillNo' },
                { header: 'Bill Date', dataKey: 'BillDate' },
                { header: 'Gross', dataKey: 'GrossAmount' },
                { header: 'Discount', dataKey: 'DiscountAmount' },
                { header: 'Net', dataKey: 'NetAmount' },
                { header: 'Due', dataKey: 'DueAmount' },
                { header: 'Department', dataKey: 'Department' },
                { header: 'User', dataKey: 'Username' }
            ];
            
            const numberFields = new Set(['GrossAmount', 'DiscountAmount', 'NetAmount', 'DueAmount']);

            const body = rows.map(row => {
                return cols.map(col => {
                    const val = row[col.dataKey];
                    if (col.dataKey === 'BillDate') {
                        return cleanText(val).replace(/ GMT.*/, '');
                    }
                    if (numberFields.has(col.dataKey)) {
                        return fmtNumberCell(val);
                    }
                    return cleanText(val);
                });
            });

            doc.autoTable({
                head: [cols.map(c => c.header)],
                body: body,
                startY: 85,
                margin: { left: 20, right: 20 },
                styles: { fontSize: 8, cellPadding: 2, lineColor: [220, 220, 220], lineWidth: 0.1, overflow: 'linebreak' },
                headStyles: { fillColor: [30, 64, 175], textColor: 255, halign: 'center' },
                columnStyles: cols.reduce((acc, c, i) => {
                    acc[i] = { halign: numberFields.has(c.dataKey) ? 'right' : 'left' };
                    return acc;
                }, {}),
                tableWidth: 'auto',
                alternateRowStyles: { fillColor: [248, 249, 251] },
                didDrawPage: function (data) {
                    const pageCount = doc.internal.getNumberOfPages();
                    doc.setFontSize(9);
                    doc.text(`Page ${data.pageNumber} of ${pageCount}`, data.settings.margin.left, doc.internal.pageSize.getHeight() - 10);
                }
            });
            doc.save(`Due_Discount_${new Date().toISOString().slice(0, 10)}.pdf`);
        };

        const logoImg = new Image();
        logoImg.crossOrigin = "Anonymous";
        logoImg.src = "{{ url_for('static', filename='logo/asarfi.png') }}";
        
        logoImg.onload = function() {
            const canvas = document.createElement('canvas');
            canvas.width = logoImg.naturalWidth;
            canvas.height = logoImg.naturalHeight;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(logoImg, 0, 0);
            const dataURL = canvas.toDataURL('image/png');
            createPdf(dataURL, logoImg.naturalWidth, logoImg.naturalHeight);
        };
        
        logoImg.onerror = function() {
            alert('Could not load hospital logo for PDF export. Proceeding without it.');
            createPdf(null, null, null);
        };
    }
      function applyDueSearch(){
        if(!dueTrackWrap) return;
        const q = (dueSearchEl?.value || '').trim().toLowerCase();
        if(!q){
          dueFiltered = [...dueData];
          renderDueTrackView(dueFiltered);
          return;
        }
        dueFiltered = dueData.filter(row=>{
          return Object.values(row || {}).some(val=>{
            if(val === null || val === undefined) return false;
            return String(val).toLowerCase().includes(q);
          });
        });
        renderDueTrackView(dueFiltered);
      }
      function setActiveView(mode){
        if(mode !== 'ipd' && mode !== 'due' && mode !== 'collections' && mode !== 'compliance'){
          activeView = null;
          viewCards.forEach(card=> card.classList.remove('active'));
          if(ipdView) ipdView.style.display = 'none';
          if(dueView) dueView.style.display = 'none';
          if(collView) collView.style.display = 'none';
          const compViewEl = document.getElementById('complianceView');
          if(compViewEl) compViewEl.style.display = 'none';
          return;
        }
        activeView = mode;
        viewCards.forEach(card=>{
          card.classList.toggle('active', card.dataset.view === mode);
        });
        const compViewEl = document.getElementById('complianceView');
        if(ipdView) ipdView.style.display = mode === 'ipd' ? 'block' : 'none';
        if(dueView) dueView.style.display = mode === 'due' ? 'block' : 'none';
        if(collView) collView.style.display = mode === 'collections' ? 'block' : 'none';
        if(compViewEl) compViewEl.style.display = mode === 'compliance' ? 'block' : 'none';
        if(dueFiltersWrap){
          if(mode === 'due') dueFiltersWrap.classList.add('is-visible');
          else dueFiltersWrap.classList.remove('is-visible');
        }
        if(mode === 'ipd'){
          revealFilters();
        }
        if(mode === 'collections'){
          const collFilters = document.getElementById('collFilters');
          if(collFilters) collFilters.classList.add('is-visible');
        }
        if(mode === 'compliance'){
          const compFilters = document.getElementById('compFilters');
          if(compFilters) compFilters.classList.add('is-visible');
        }
      }
      function updateKpis(rows){
        if(!kpiBilling || !kpiDue){
          return;
        }
        if(!rows || !rows.length){
          kpiBilling.innerHTML = '<div class="kpi-empty">Load a unit to view billing KPIs.</div>';
          kpiDue.innerHTML = '<div class="kpi-empty">Load a unit to review due health.</div>';
          return;
        }
        const sums = rows.reduce((acc,row)=>{
          const net = parseNumber(row.NetAmount);
          const gross = parseNumber(row.GrossAmount);
          const disc = parseNumber(row.DiscountAmount);
          const ip = parseNumber(row.IPDRecp);
          const ph = parseNumber(row.PhBill);
          const phRet = parseNumber(row.PHRet);
          const totalBill = net + ph;
          const due = totalBill + phRet - ip;
          acc.count += 1;
          acc.gross += gross;
          acc.net += net;
          acc.discount += disc;
          acc.collections += ip;
          acc.ph += ph;
          acc.phret += phRet;
          acc.due += due;
          const pay = payLabel(row);
          if(pay === 'Cash') acc.cash += net;
          else if(pay === 'Cashless') acc.cashless += net;
          return acc;
        },{count:0,gross:0,net:0,discount:0,collections:0,ph:0,phret:0,due:0,cash:0,cashless:0});
        const avgNet = sums.count ? sums.net / sums.count : 0;
        const totalBilling = sums.net + sums.ph;
        const duePct = totalBilling ? (sums.due / totalBilling)*100 : 0;
        kpiBilling.innerHTML = [
          renderKpiBox('Total Net Billing', sums.net),
          renderKpiBox('Gross Billing', sums.gross),
          renderKpiBox('Cash Net', sums.cash),
          renderKpiBox('Cashless Net', sums.cashless),
          renderKpiBox('Collections (IPD)', sums.collections),
          renderKpiBox('Average Net Bill', avgNet)
        ].join('');
        kpiDue.innerHTML = [
          renderKpiBox('Outstanding Due', sums.due),
          renderKpiBox('Discounts', sums.discount),
          renderKpiBox('Write-offs / Returns', sums.phret),
          renderKpiBox('Pharmacy Billing', sums.ph),
          renderKpiBox('Due % of Billing', duePct,'percent')
        ].join('');
      }
      const buildBillingSheet = (rows, sheetName) => {
        // REMOVED: if (!rows.length) return null; 
        // We now allow empty rows to generate a sheet with 0 totals.

        // 1. Get User Name
        const userText = document.querySelector('.fab-menu div')?.textContent?.trim() || 'System User';
        const cleanUser = userText.replace('??', '').trim();

        const headerRow = ['Sl.', 'Reg.No.', 'Patient', 'Disc.Dt', 'Bill No.', 'RadioTotal', 'LabTotal', 'Hos. Tot.', 'Disc.', 'Net Bill', 'Ph. Bill', 'Total Bill', 'PHRet', 'IP Rec.', 'Due', 'Remarks'];
        
        // 2. Top Header Format
        const sheetData = [
          ['ASARFI HOSPITAL'],
          [`DISCHARGE REPORT (${sheetName.toUpperCase()})`],
          [`Unit: ${unitSel.value || '-'}   |   Date: ${fromEl.value || '-'}${fromEl.value === toEl.value ? '' : ' to ' + (toEl.value || '-')}   |   Exported By: ${cleanUser}`]
        ];
        
        sheetData.push(headerRow);
        const headerRowIndex = sheetData.length - 1;

        const categoryRows = [];
        const departmentRows = [];
        const doctorRows = [];
        const ptMap = new Map();
        
        // --- NEW LOGIC: Handle Empty Data ---
        if (rows.length === 0) {
           // Add a spacer and a clear message
           sheetData.push(['', '', 'NO DISCHARGES FOUND FOR THIS CATEGORY', '', '', '', '', '', '', '', '', '', '', '', '', '']);
           // Mark this row as a "Category" row just so it gets bold styling later
           categoryRows.push(sheetData.length - 1); 
        }

        // Grouping Logic (Won't run if rows is empty)
        rows.forEach(row=>{
          const ptKey = cleanText(row.PatientType) || 'GENERAL';
          const deptKey = cleanText(row.Department_Name) || 'General';
          const docKey = cleanText(row.DoctorName) || 'NA';
          if(!ptMap.has(ptKey)) ptMap.set(ptKey, new Map());
          const deptMap = ptMap.get(ptKey);
          if(!deptMap.has(deptKey)) deptMap.set(deptKey, new Map());
          const docMap = deptMap.get(deptKey);
          if(!docMap.has(docKey)) docMap.set(docKey, []);
          docMap.get(docKey).push(row);
        });

        let serial = 1;
        const totals = { RadioTotal:0, LabTotal:0, HospitalTotal:0, DiscountAmount:0, NetAmount:0, PhBill:0, TotalBill:0, PHRet:0, IPDRecp:0, DueAmount:0 };
        const ensurePrefix = (name)=> { if(!name) return 'Doctor NA'; const trim = name.trim(); if(/^dr\.?/i.test(trim)) return trim; return `Dr. ${trim}`; };

        // Build Data Rows
        ptMap.forEach((deptMap, ptKey)=>{
          sheetData.push([`${ptKey.toUpperCase()} (${sheetName} Category)`]);
          categoryRows.push(sheetData.length - 1);
          deptMap.forEach((docMap, deptKey)=>{
            sheetData.push(['', deptKey || 'Department']);
            departmentRows.push(sheetData.length - 1);
            docMap.forEach((list, docKey)=>{
              sheetData.push(['', '', ensurePrefix(docKey)]);
              doctorRows.push(sheetData.length - 1);
              list.forEach(row=>{
                const net = Number(String(row.NetAmount || 0).replace(/,/g,'')) || 0;
                const ph = Number(String(row.PhBill || 0).replace(/,/g,'')) || 0;
                const ipRec = Number(String(row.IPDRecp || 0).replace(/,/g,'')) || 0;
                const due = row.DueAmount !== undefined && row.DueAmount !== null && row.DueAmount !== '' ? parseNumber(row.DueAmount) : (net - ipRec);
                const radio = parseNumber(row.RadioTotal);
                const lab = parseNumber(row.LabTotal);
                const hos = parseNumber(row.HospitalTotal);
                const disc = parseNumber(row.DiscountAmount);
                const totalBill = net + ph;
                
                totals.RadioTotal += radio;
                totals.LabTotal += lab;
                totals.HospitalTotal += hos;
                totals.DiscountAmount += disc;
                totals.NetAmount += net;
                totals.PhBill += ph;
                totals.TotalBill += totalBill;
                totals.PHRet += parseNumber(row.PHRet);
                totals.IPDRecp += ipRec;
                totals.DueAmount += due;

                sheetData.push([
                  serial++,
                  cleanText(row.Registration_No),
                  cleanText(row.patentname),
                  fmtDateCell(row.DischargeDate),
                  cleanText(row.BillNo),
                  fmtNumberCell(radio),
                  fmtNumberCell(lab),
                  fmtNumberCell(hos),
                  fmtNumberCell(disc),
                  fmtNumberCell(row.NetAmount),
                  fmtNumberCell(row.PhBill),
                  fmtNumberCell(totalBill),
                  fmtNumberCell(row.PHRet),
                  fmtNumberCell(row.IPDRecp),
                  fmtNumberCell(due),
                  cleanText(row.Remarks)
                ]);
              });
            });
          });
           sheetData.push(new Array(headerRow.length).fill(''));
        });

        // Add Grand Total Row (Will show 0.00 if empty)
        const totalRow = new Array(headerRow.length).fill('');
        totalRow[4] = 'GRAND TOTAL';
        totalRow[5] = fmtNumberCell(totals.RadioTotal);
        totalRow[6] = fmtNumberCell(totals.LabTotal);
        totalRow[7] = fmtNumberCell(totals.HospitalTotal);
        totalRow[8] = fmtNumberCell(totals.DiscountAmount);
        totalRow[9] = fmtNumberCell(totals.NetAmount);
        totalRow[10] = fmtNumberCell(totals.PhBill);
        totalRow[11] = fmtNumberCell(totals.TotalBill);
        totalRow[12] = fmtNumberCell(totals.PHRet);
        totalRow[13] = fmtNumberCell(totals.IPDRecp);
        totalRow[14] = fmtNumberCell(totals.DueAmount);
        sheetData.push(totalRow);
        const totalRowIndex = sheetData.length - 1;

        // --- CREATE WORKBOOK ---
        const ws = XLSX.utils.aoa_to_sheet(sheetData);

        ws['!merges'] = [
          {s:{r:0,c:0}, e:{r:0,c:headerRow.length-1}},
          {s:{r:1,c:0}, e:{r:1,c:headerRow.length-1}},
          {s:{r:2,c:0}, e:{r:2,c:headerRow.length-1}}
        ];

        ws['!cols'] = [
          {wch:4},{wch:16},{wch:28},{wch:12},{wch:20},
          {wch:12},{wch:12},{wch:12},{wch:10},{wch:12},
          {wch:12},{wch:12},{wch:10},{wch:10},{wch:10},{wch:16}
        ];

        const freezeRow = headerRowIndex + 1;
        ws['!freeze'] = { xSplit: 0, ySplit: freezeRow };

        const borderStyle = {
           top: {style: "thin", color: {auto: 1}},
           bottom: {style: "thin", color: {auto: 1}},
           left: {style: "thin", color: {auto: 1}},
           right: {style: "thin", color: {auto: 1}}
        };

        const headerStyle = {
          font:{ bold:true, color:{ rgb:'FFFFFFFF' } },
          fill:{ patternType:'solid', fgColor:{ rgb:'FF1E3A8A' } }, 
          alignment:{ horizontal:'center', vertical:'center' },
          border: borderStyle
        };

        const titleStyle = { font:{ bold:true, sz:14, color: { rgb: 'FF1E3A8A' } }, alignment:{ horizontal:'center' }, fill: { patternType: 'solid', fgColor: { rgb: 'FFF1F5F9' } } };
        const subTitleStyle = { font:{ bold:true, sz:11 }, alignment:{ horizontal:'center' }, fill: { patternType: 'solid', fgColor: { rgb: 'FFF1F5F9' } } };
        const groupTitleStyle = { font:{ bold:true, sz:11 }, alignment: {horizontal: "left"} };
        const totalRowStyle = { font:{ bold:true }, fill:{ patternType:'solid', fgColor:{ rgb:'FFF0F9FF' } }, border: borderStyle };

        [0,1,2].forEach(r => {
            const st = r === 0 ? titleStyle : subTitleStyle;
            const addr = XLSX.utils.encode_cell({r, c:0});
            applyCellStyle(ws, addr, st);
        });

        for(let c=0; c<headerRow.length; c++){
          const addr = XLSX.utils.encode_cell({r:headerRowIndex, c});
          applyCellStyle(ws, addr, headerStyle);
        }

        const discIndex = headerRow.indexOf('Disc.');
        const dueIndex = headerRow.indexOf('Due');

        for(let R = headerRowIndex; R <= totalRowIndex; ++R) {
            const isTotalRow = (R === totalRowIndex);
            const isGroupRow = categoryRows.includes(R) || departmentRows.includes(R) || doctorRows.includes(R);

            for(let C = 0; C < headerRow.length; ++C) {
                const addr = XLSX.utils.encode_cell({r:R, c:C});
                if(!ws[addr]) ws[addr] = { t:'s', v:'' };

                if(!ws[addr].s) ws[addr].s = {};
                ws[addr].s.border = borderStyle;

                if(isGroupRow) ws[addr].s.font = { bold: true };
                if(isTotalRow) ws[addr].s = { ...ws[addr].s, ...totalRowStyle };

                if(R > headerRowIndex && !isGroupRow && !isTotalRow) {
                   const cellValRaw = ws[addr].v;
                   const val = parseNumber(cellValRaw); 
                   if(C === discIndex && val > 0) ws[addr].s.fill = { patternType:'solid', fgColor:{ rgb:'FFFFFF00' } };
                   if(C === dueIndex) {
                      if(val > 0) ws[addr].s.fill = { patternType:'solid', fgColor:{ rgb:'FFFC8C8C' } };
                      else if (val < 0) ws[addr].s.fill = { patternType:'solid', fgColor:{ rgb:'FFFFD8B1' } };
                   }
                }
            }
        }

        return ws;
      };
      const buildFlatBillingSheet = (rows, sheetName) => {
        if (!rows || !rows.length) return null;

        // Get User Name from the DOM
        const userText = document.querySelector('.fab-menu div')?.textContent?.trim() || 'System User';
        const cleanUser = userText.replace('??', '').trim();

        const headerRow = [
            'Sl.', 'Reg.No.', 'Patient', 'Disc.Dt', 'Bill No.', 'RadioTotal', 'LabTotal', 
            'Hos. Tot.', 'Disc.', 'Net Bill', 'Ph. Bill', 'Total Bill', 'PHRet', 'IP Rec.', 'Due', 
            'PayType', 'PatientType', 'PatientSubType', 'Department', 'Doctor', 'Remarks'
        ];

        const sheetData = [
            ['ASARFI HOSPITAL'],
            ['DISCHARGE REPORT (ALL)'],
            [`Unit: ${unitSel.value || '-'}   |   Date: ${fromEl.value || '-'}${fromEl.value === toEl.value ? '' : ' to ' + (toEl.value || '-')}   |   Exported By: ${cleanUser}`]
        ];
        sheetData.push(headerRow);
        const headerRowIndex = sheetData.length - 1;

        let serial = 1;
        rows.forEach(row => {
            const net = parseNumber(row.NetAmount);
            const ph = parseNumber(row.PhBill);
            const ipRec = parseNumber(row.IPDRecp);
            const due = row.DueAmount !== undefined && row.DueAmount !== null && row.DueAmount !== '' ? parseNumber(row.DueAmount) : (net - ipRec);
            const totalBill = net + ph;

            sheetData.push([
                serial++, 
                cleanText(row.Registration_No), 
                cleanText(row.patentname), 
                fmtDateCell(row.DischargeDate),
                cleanText(row.BillNo), 
                parseNumber(row.RadioTotal), 
                parseNumber(row.LabTotal), 
                parseNumber(row.HospitalTotal),
                parseNumber(row.DiscountAmount), 
                parseNumber(row.NetAmount), 
                parseNumber(row.PhBill), 
                parseNumber(totalBill),
                parseNumber(row.PHRet), 
                parseNumber(row.IPDRecp), 
                due, 
                payLabel(row),
                cleanText(row.PatientType), 
                cleanText(row.PatientSubType), 
                cleanText(row.Department_Name),
                cleanText(row.DoctorName), 
                cleanText(row.Remarks)
            ]);
        });

        const ws = XLSX.utils.aoa_to_sheet(sheetData);

        // 4. Merge Titles (Center Alignment)
        ws['!merges'] = [
            { s: { r: 0, c: 0 }, e: { r: 0, c: headerRow.length - 1 } },
            { s: { r: 1, c: 0 }, e: { r: 1, c: headerRow.length - 1 } },
            { s: { r: 2, c: 0 }, e: { r: 2, c: headerRow.length - 1 } }
        ];

        // 5. Set Column Widths
        ws['!cols'] = [
            { wch: 5 }, { wch: 16 }, { wch: 28 }, { wch: 12 }, { wch: 20 },
            { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 10 }, { wch: 12 },
            { wch: 12 }, { wch: 12 }, { wch: 10 }, { wch: 10 }, { wch: 10 },
            { wch: 10 }, { wch: 15 }, { wch: 15 }, { wch: 20 }, { wch: 20 }, { wch: 16 }
        ];

        // 6. Freeze Panes (Lock Header)
        const freezeRow = headerRowIndex + 1;
        ws['!freeze'] = { xSplit: 0, ySplit: freezeRow };

        // 7. Add Auto-Filters
        if (ws['!ref']) {
            const ref = XLSX.utils.decode_range(ws['!ref']);
            ref.s.r = headerRowIndex; 
            ws['!autofilter'] = { ref: XLSX.utils.encode_range(ref) };
        }

        // 8. Apply Styling
        // Style: Dark Blue Header with White Text (Professional Look)
        const headerStyle = {
            font: { bold: true, color: { rgb: 'FFFFFFFF' } },
            fill: { patternType: 'solid', fgColor: { rgb: 'FF1E3A8A' } }, // Dark Blue
            alignment: { horizontal: 'center', vertical: 'center' },
            border: {
                top: {style: "thin", color: {auto: 1}},
                bottom: {style: "thin", color: {auto: 1}},
                left: {style: "thin", color: {auto: 1}},
                right: {style: "thin", color: {auto: 1}}
            }
        };
        
        for (let c = 0; c < headerRow.length; c++) {
            const addr = XLSX.utils.encode_cell({ r: headerRowIndex, c });
            applyCellStyle(ws, addr, headerStyle);
        }

        // Style: Top Title Rows (Centered, Bold, Larger)
        const titleStyle = { 
            font: { bold: true, sz: 14, color: { rgb: 'FF1E3A8A' } }, 
            alignment: { horizontal: 'center', vertical: 'center' },
            fill: { patternType: 'solid', fgColor: { rgb: 'FFF1F5F9' } } // Very light gray bg
        };
        const subTitleStyle = { 
            font: { bold: true, sz: 11 }, 
            alignment: { horizontal: 'center', vertical: 'center' },
            fill: { patternType: 'solid', fgColor: { rgb: 'FFF1F5F9' } }
        };

        // Apply Title Styles
        applyCellStyle(ws, XLSX.utils.encode_cell({ r: 0, c: 0 }), titleStyle); // Hospital Name
        applyCellStyle(ws, XLSX.utils.encode_cell({ r: 1, c: 0 }), subTitleStyle); // Report Name
        applyCellStyle(ws, XLSX.utils.encode_cell({ r: 2, c: 0 }), subTitleStyle); // Details

        return ws;
      };
      fromEl.value = today;
      toEl.value = today;
      dueFromEl.value = today;
      dueToEl.value = today;
      if(collFromEl) collFromEl.value = today;
      if(collToEl) collToEl.value = today;
      if(compFromEl) compFromEl.value = today;
      if(compToEl) compToEl.value = today;
      if(compFromEl) compFromEl.value = today;
      if(compToEl) compToEl.value = today;

      // --- Filter Helper for WYSIWYG ---
      function getFilteredData() {
        const q = (searchEl.value || '').trim().toLowerCase();
        if (!q) return allData;
        return allData.filter(r => {
            const reg = (r.Registration_No || '').toString().toLowerCase();
            const name = (r.patentname || '').toString().toLowerCase();
            const bill = (r.BillNo || '').toString().toLowerCase();
            const doc = (r.DoctorName || '').toString().toLowerCase();
            const dept = (r.Department_Name || '').toString().toLowerCase();
            const pt = (r.PatientType || '').toString().toLowerCase();
            const pst = (r.PatientSubType || '').toString().toLowerCase();
            return reg.includes(q) || name.includes(q) || bill.includes(q) || doc.includes(q) || dept.includes(q) || pt.includes(q) || pst.includes(q);
        });
      }

      let allData = [];
      let remainingSec = 0;
      let filtersVisible = false;
      let activeView = null;
      let dueData = [];
      let dueFiltered = [];
      updateKpis([]);
      const revealFilters = ()=>{
        if(filtersVisible || !controlsWrap) return;
        controlsWrap.classList.add('is-visible');
        filtersVisible = true;
      };
      billingCard?.addEventListener('click', ()=>{
        revealFilters();
        controlsWrap?.scrollIntoView({behavior:'smooth', block:'center'});
      });

      function render(){
        // Use centralized filter function
        const data = getFilteredData();
        
        updateKpis(data);
        if(!data.length){
          tableWrap.innerHTML = '<div style="padding:12px; color:#6b7280;">No data found.</div>';
          return;
        }
        const payBuckets = { "Cash": {}, "Cashless": {}, "Other": {} };
        data.forEach(r=>{
          const payRaw = r.paytype || r.PayType || '';
          const payType = String(payRaw) === '1' ? 'Cash' : (String(payRaw) === '2' ? 'Cashless' : 'Other');
          const reg = (r.Registration_No || '').toString();
          if(!payBuckets[payType][reg]) payBuckets[payType][reg] = [];
          payBuckets[payType][reg].push(r);
        });

        let html = '';
        ["Cash","Cashless","Other"].forEach(pay=>{
          const groups = payBuckets[pay];
          if(!groups || Object.keys(groups).length === 0) return;
          const payId = `pay-${pay.toLowerCase()}`;
          const flatRows = Object.values(groups).flat();
          const netSum = flatRows.reduce((s,r)=> s + (parseFloat(r.NetAmount)||0), 0);
          const discSum = flatRows.reduce((s,r)=> s + (parseFloat(r.DiscountAmount)||0), 0);
          const dueSum = flatRows.reduce((s,r)=> s + ((parseFloat(r.NetAmount)||0) - (parseFloat(r.IPDRecp)||0)), 0);
          const fmt = (n)=> new Intl.NumberFormat('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
          const rupee = '?';
          html += `<div class="pay-section"><div class="pay-title" data-target="${payId}">${pay} <span style="font-size:12px; font-weight:700; color:#475569;">(Net: ${rupee} ${fmt(netSum)}, Disc: ${rupee} ${fmt(discSum)}, Due: ${rupee} ${fmt(dueSum)})</span></div><div id="${payId}" style="display:none; padding:12px;">`;
          let idx = 0;
          Object.entries(groups).forEach(([reg, rows])=>{
            const name = rows[0]?.patentname || '';
            const tid = `bill-${pay}-${idx++}`;
            const cols = Object.keys(rows[0] || {});
            const pt = rows[0]?.PatientType || '';
            const pst = rows[0]?.PatientSubType || '';
            const dept = rows[0]?.Department_Name || '';
            const sum = (key) => rows.reduce((s,r)=> s + (parseFloat(r[key])||0), 0);
            const gross = sum('GrossAmount');
            const disc  = sum('DiscountAmount');
            const net   = sum('NetAmount');
            const due   = sum('NetAmount') - sum('IPDRecp');
            const head = `${reg} - ${name} (${rows.length} rows)`;
            const subtitle = `Pay: ${pay} | PatientType: ${pt} | SubType: ${pst} | Dept: ${dept} | Gross: ${fmt2(gross)} | Disc: ${fmt2(disc)} | Net: ${fmt2(net)} | Due: ${fmt2(due)}`;
            html += `
              <div class="hist-group">
                <div class="hist-head" data-target="${tid}">
                  <span>
                    <div>${head}</div>
                    <div style="font-weight:600; font-size:12px; color:#1f2937;">${subtitle}</div>
                  </span>
                  <span style="font-weight:600; font-size:12px; color:#475569;">${unitSel.value}</span>
                </div>
                <div class="hist-body" id="${tid}">
                  <table>
                    <thead><tr>${cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead>
                    <tbody>
                      ${rows.map(r=>`<tr>${cols.map(c=>{
                        let val = r[c];
                        if(c==='DischargeDate'){ val = val===null||val===undefined?'':String(val).replace(/ GMT.*/,''); }
                        else if(amountFields.has(c)){ val = fmt2(val); }
                        return `<td>${val===null||val===undefined?'':val}</td>`;
                      }).join('')}</tr>`).join('')}
                    </tbody>
                  </table>
                </div>
              </div>
            `;
          });
          html += '</div></div>';
        });
        tableWrap.innerHTML = html;
        tableWrap.querySelectorAll('.pay-title').forEach(p=>{
          p.addEventListener('click', ()=>{
            const t = document.getElementById(p.dataset.target);
            if(t){
              t.style.display = (t.style.display === 'none' || t.style.display === '') ? 'block' : 'none';
            }
          });
        });
        tableWrap.querySelectorAll('.hist-head').forEach(h=>{
          h.addEventListener('click', ()=>{
            const b = document.getElementById(h.dataset.target);
            if(b){ b.classList.toggle('open'); }
          });
        });
        const first = tableWrap.querySelector('.hist-body');
        if(first){ first.classList.add('open'); }
      }

      async function loadCollections(){
        const unit = (collUnitSel?.value || unitSel?.value || '').trim();
        const from = collFromEl?.value || today;
        const to = collToEl?.value || today;
        if(collStatus) collStatus.textContent = 'Loading collections...';
        if(collTable) collTable.innerHTML = loadingHtml;
        try{
          const res = await fetch(`/api/mis/collections?unit=${encodeURIComponent(unit)}&from=${from}&to=${to}`);
          const data = await res.json();
          if(!res.ok || data.status !== 'success') throw new Error(data.message || 'Failed to load collections');
          collData = data.data || [];
          collPage = 1;
          applyCollSearch();
          if(collStatus) collStatus.textContent = `Loaded ${collData.length} receipts for ${unit}`;
        }catch(err){
          if(collStatus) collStatus.textContent = `Collections error: ${err.message}`;
          if(kpiCollections) kpiCollections.innerHTML = '<div class="kpi-empty">Unable to load collections.</div>';
          if(collTable) collTable.innerHTML = '<div class="kpi-empty">Unable to load collections.</div>';
        }
      }

      async function loadCompliance(){
        const unit = (compUnitSel?.value || unitSel?.value || '').trim();
        const from = compFromEl?.value || today;
        const to = compToEl?.value || today;
        if(compStatus) compStatus.textContent = 'Loading compliance...';
        if(compTable) compTable.innerHTML = loadingHtml;
        try{
          const res = await fetch(`/api/mis/compliance?unit=${encodeURIComponent(unit)}&from=${from}&to=${to}`);
          const data = await res.json();
          if(!res.ok || data.status !== 'success') throw new Error(data.message || 'Failed to load compliance');
          const rows = data.data || [];
          if(!rows.length){
            compKpi.innerHTML = '<div class="kpi-empty">No records.</div>';
            compTable.innerHTML = '<div class="kpi-empty">No compliance records.</div>';
            return;
          }
          const totals = rows.reduce((acc,r)=>{
            acc.receipts += parseNumber(r.receipt_amount);
            acc.revenue += parseNumber(r.revenue_amount);
            acc.suspense += parseNumber(r.suspense_amount);
            return acc;
          },{receipts:0,revenue:0,suspense:0});
          compKpi.innerHTML = `
            <div class="kpi"><div class="kpi-label">Total Receipts</div><div class="kpi-value">${formatINR(totals.receipts)}</div><div class="kpi-label" style="margin-top:4px;">Sum of all receipts in range</div></div>
            <div class="kpi"><div class="kpi-label">Matched Revenue</div><div class="kpi-value">${formatINR(totals.revenue)}</div><div class="kpi-label" style="margin-top:4px;">Revenue applied once per key</div></div>
            <div class="kpi"><div class="kpi-label">Suspense Amount</div><div class="kpi-value">${formatINR(totals.suspense)}</div><div class="kpi-label" style="margin-top:4px;">Unmatched receipts only</div></div>
          `;
          // Group by key to show collapsible detail for multi-receipt cases
          const groups = {};
          rows.forEach(r=>{
            const k = `${cleanText(r.key_type)}|${cleanText(r.key)}`;
            if(!groups[k]) groups[k] = { head: r, list: [] };
            groups[k].list.push(r);
          });
          const body = Object.entries(groups).map(([k,data], idx)=>{
            const keyType = cleanText(data.head.key_type);
            const key = cleanText(data.head.key);
            const patient = cleanText(data.head.patient);
            const reg = cleanText(data.head.reg_no);
            const visit = cleanText(data.head.visit_no);
            const backdated = parseNumber(data.head.backdated_match) === 1;
            const sumReceipt = data.list.reduce((s,r)=> s + parseNumber(r.receipt_amount),0);
            const sumRevenue = data.list.reduce((s,r)=> s + parseNumber(r.revenue_amount),0);
            const sumSuspense = data.list.reduce((s,r)=> s + parseNumber(r.suspense_amount),0);
            const detailRows = data.list.map(r=>`
              <tr>
                <td>${cleanText(r.receipt_type)}</td>
                <td>${cleanText(r.pay_mode)}</td>
                <td>${fmtDateCell(r.receipt_date)}</td>
                <td>${formatINR(r.receipt_amount)}</td>
                <td>${formatINR(r.revenue_amount)}</td>
                <td>${formatINR(r.suspense_amount)}</td>
              </tr>
            `).join('');
            const detailId = `comp-detail-${idx}`;
            return `
              <tr class="comp-summary" data-target="${detailId}" data-expanded="false" style="cursor:pointer;${backdated?'background:#ecfdf3;':''}">
                <td><span class="caret">?</span> <span class="caret-label">${keyType}</span></td>
                <td>${key}</td>
                <td style="min-width:220px;">${patient}</td>
                <td style="min-width:120px;">${reg}</td>
                <td style="min-width:120px;">${visit}</td>
                <td>${formatINR(sumReceipt)}</td>
                <td>${formatINR(sumRevenue)}</td>
                <td>${formatINR(sumSuspense)}</td>
              </tr>
              <tr id="${detailId}" class="comp-detail" style="display:none; background:#f8fafc;">
                <td colspan="8">
                  <table style="width:100%; border-collapse:collapse;">
                    <thead>
                      <tr>
                        <th style="text-align:left;">Receipt Type</th>
                        <th style="text-align:left;">Payment Mode</th>
                        <th style="text-align:left;">Receipt Date</th>
                        <th style="text-align:left;">Receipt Amount</th>
                        <th style="text-align:left;">Revenue Amount</th>
                        <th style="text-align:left;">Suspense</th>
                      </tr>
                    </thead>
                    <tbody>${detailRows}</tbody>
                  </table>
                </td>
              </tr>
            `;
          }).join('');
          compTable.innerHTML = `
            <div class="table-wrap-inner" style="overflow-x:auto;">
              <table style="min-width:1000px;">
                <thead>
                  <tr>
                    <th>Key Type</th>
                    <th>Key</th>
                    <th>Patient</th>
                    <th>Reg No</th>
                    <th>Visit No</th>
                    <th>Receipt Amount</th>
                    <th>Revenue Amount</th>
                    <th>Suspense</th>
                  </tr>
                </thead>
                <tbody>${body}</tbody>
              </table>
            </div>
          `;
          if(compStatus) compStatus.textContent = `Loaded ${rows.length} records for ${unit}`;
          // toggle details
          compTable.querySelectorAll('.comp-summary').forEach(row=>{
            row.addEventListener('click', ()=>{
              const targetId = row.dataset.target;
              const detailRow = document.getElementById(targetId);
              if(detailRow){
                detailRow.style.display = detailRow.style.display === 'none' ? 'table-row' : 'none';
                const caretCell = row.querySelector('td:first-child');
                if(caretCell){
                  const base = caretCell.textContent.replace(/^[??]\\s*/,'').trim();
                  caretCell.textContent = (detailRow.style.display === 'none' ? '? ' : '? ') + base;
                }
              }
            });
          });
        }catch(err){
          if(compStatus) compStatus.textContent = `Compliance error: ${err.message}`;
          compKpi.innerHTML = '<div class="kpi-empty">Unable to load compliance.</div>';
          compTable.innerHTML = '<div class="kpi-empty">Unable to load compliance.</div>';
        }
      }

      async function load(){
        const unit = unitSel.value || '';
        const from = fromEl.value || today;
        const to = toEl.value || today;
        statusEl.textContent = 'Loading...';
        tableWrap.innerHTML = '<div class="loading-overlay"><div class="spinner"></div><div>Fetching data, please wait…</div></div>';
        try{
          revealFilters();
          const res = await fetch(`/api/mis/billing_data?unit=${encodeURIComponent(unit)}&from=${from}&to=${to}`);
          const data = await res.json();
          if(!res.ok || data.status !== 'success') throw new Error(data.message || 'Failed to load');
          allData = data.data || [];
          statusEl.textContent = `Loaded ${allData.length} rows for ${unit}`;
          render();
        }catch(err){
          statusEl.textContent = `Error: ${err.message}`;
        }
      }

      function fmtSecs(s){
        s = Math.max(0, Math.floor(s||0));
        const m = Math.floor(s/60).toString().padStart(2,'0');
        const sec = (s%60).toString().padStart(2,'0');
        return `${m}:${sec}`;
      }
      function updateTimerDisplay(){ if(fabTimer) fabTimer.textContent = fmtSecs(remainingSec); }
      async function refreshSessionTimer(){
        try{
          const res = await fetch('/session_remaining');
          const data = await res.json();
          if(res.ok && typeof data.remaining_seconds !== 'undefined'){
            remainingSec = Math.max(0, Math.floor(data.remaining_seconds));
            updateTimerDisplay();
          }
        }catch(e){}
      }
      setInterval(()=>{ if(remainingSec>0){ remainingSec -= 1; updateTimerDisplay(); } }, 1000);
      setInterval(refreshSessionTimer, 20000);
      refreshSessionTimer();
      window.addEventListener('sessionRefreshed', () => {
        refreshSessionTimer();
      });
      viewCards.forEach(card=>{
        card.addEventListener('click', ()=>{
          const mode = card.dataset.view;
          setActiveView(mode === 'due' ? 'due' : (mode === 'collections' ? 'collections' : (mode === 'compliance' ? 'compliance' : 'ipd')));
        });
      });
      dueLoadBtn?.addEventListener('click', ()=>{
        const unit = dueUnitSel.value || '';
        const from = dueFromEl.value || today;
        const to = dueToEl.value || today;
        fetchDiscountDue(unit, from, to);
      });
      dueSearchEl?.addEventListener('input', ()=>applyDueSearch());
      dueExportXlsxBtn?.addEventListener('click', exportDueXlsx);
      dueExportPdfBtn?.addEventListener('click', exportDuePdf);
      collLoadBtn?.addEventListener('click', loadCollections);
      collReceiptTypeSel?.addEventListener('change', applyCollSearch);
      collExportBtn?.addEventListener('click', ()=>{
        const unit = (collUnitSel?.value || unitSel?.value || '').trim();
        const from = collFromEl?.value || today;
        const to = collToEl?.value || today;
        if(!unit){
          alert('Select a unit to export.');
          return;
        }
        const url = `/api/mis/collections/export_excel?unit=${encodeURIComponent(unit)}&from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;
        window.open(url, '_blank');
      });
      compLoadBtn?.addEventListener('click', loadCompliance);
      // Start with no active view; user clicks a card to open a panel.
      setActiveView(null);

      // fab menu toggle
      if(fabToggle && fabMenu){
          fabToggle.addEventListener('click', (e) => {
              e.stopPropagation();
              fabMenu.classList.toggle('open');
          });
          document.addEventListener('click', (e)=>{
            if(!e.target.closest('.fab-user')){
              fabMenu.classList.remove('open');
            }
          });
      }

      loadBtn.addEventListener('click', load);
      searchEl.addEventListener('input', render);
      collSearchEl?.addEventListener('input', applyCollSearch);

      // --- FIX: Add Event Listeners for IPD Export Buttons ---

      // 1. Excel Export Handler (With Grand Summary Sheet)
      // 1. Excel Export Handler (With Grand Summary Sheet)
      // 1. Excel Export Handler (Always generates sheets, even if empty)
      if (exportBtn) {
        exportBtn.addEventListener('click', () => {
          const dataToExport = (typeof getFilteredData === 'function') ? getFilteredData() : allData;

          // Only block if absolutely NO data exists at all (not just specific categories)
          if (!dataToExport) {
            alert('No data available to export.');
            return;
          }

          const wb = XLSX.utils.book_new();
          
          // 1. All Discharges Sheet
          const wsAll = buildFlatBillingSheet(dataToExport, 'All'); 
          if(wsAll) XLSX.utils.book_append_sheet(wb, wsAll, 'All Discharges'); 

          // 2. Filter Data
          const cashRows = dataToExport.filter(r => String(r.paytype || r.PayType) === '1');
          const cashlessRows = dataToExport.filter(r => String(r.paytype || r.PayType) !== '1');

          // 3. Generate Cash Sheet (Even if empty)
          const wsCash = buildBillingSheet(cashRows, 'Cash');
          if(wsCash) XLSX.utils.book_append_sheet(wb, wsCash, 'Cash');
          
          // 4. Generate Cashless Sheet (Even if empty)
          const wsCashless = buildBillingSheet(cashlessRows, 'Cashless');
          if(wsCashless) XLSX.utils.book_append_sheet(wb, wsCashless, 'Cashless');

          XLSX.writeFile(wb, `IPD_Billing_${unitSel.value}_${today}.xlsx`);
        });
      }

      // 2. PDF Export Handler (Split into Cash & Cashless Sheets + ALL Columns)
      if (exportPdfBtn) {
        exportPdfBtn.addEventListener('click', () => {
          const dataToExport = (typeof getFilteredData === 'function') ? getFilteredData() : allData;

          if (!dataToExport || !dataToExport.length) {
            alert('No data available to export.');
            return;
          }

          // Filter Data
          const cashRows = dataToExport.filter(r => String(r.paytype || r.PayType) === '1');
          const cashlessRows = dataToExport.filter(r => String(r.paytype || r.PayType) !== '1');

          const { jsPDF } = window.jspdf;
          const doc = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });

          // Expanded Columns List
          const cols = [
            { header: 'RegNo', dataKey: 'Registration_No' },
            { header: 'Patient', dataKey: 'patentname' },
            { header: 'Bill No', dataKey: 'BillNo' },
            { header: 'Date', dataKey: 'DischargeDate' },
            { header: 'Radio', dataKey: 'RadioTotal' },
            { header: 'Lab', dataKey: 'LabTotal' },
            { header: 'Hosp', dataKey: 'HospitalTotal' },
            { header: 'Disc', dataKey: 'DiscountAmount' },
            { header: 'Net', dataKey: 'NetAmount' },
            { header: 'Pharm', dataKey: 'PhBill' },
            { header: 'Ret', dataKey: 'PHRet' },
            { header: 'Rec', dataKey: 'IPDRecp' },
            { header: 'Due', dataKey: 'DueAmount' },
            { header: 'Dept', dataKey: 'Department_Name' },
            { header: 'Doctor', dataKey: 'DoctorName' }
          ];

          // Helper to format data
          const formatBody = (rows) => rows.map(row => {
            const net = Number(row.NetAmount || 0);
            const ip = Number(row.IPDRecp || 0);
            const due = (row.DueAmount !== undefined && row.DueAmount !== null) ? Number(row.DueAmount) : (net - ip);

            return {
              Registration_No: cleanText(row.Registration_No),
              patentname: cleanText(row.patentname),
              BillNo: cleanText(row.BillNo),
              DischargeDate: fmtDateCell(row.DischargeDate),
              RadioTotal: fmtNumberCell(row.RadioTotal),
              LabTotal: fmtNumberCell(row.LabTotal),
              HospitalTotal: fmtNumberCell(row.HospitalTotal),
              DiscountAmount: fmtNumberCell(row.DiscountAmount),
              NetAmount: fmtNumberCell(row.NetAmount),
              PhBill: fmtNumberCell(row.PhBill),
              PHRet: fmtNumberCell(row.PHRet),
              IPDRecp: fmtNumberCell(row.IPDRecp),
              DueAmount: fmtNumberCell(due),
              Department_Name: cleanText(row.Department_Name),
              DoctorName: cleanText(row.DoctorName)
            };
          });

          // Helper function to draw a page/table
          const drawSheet = (title, rows) => {
            doc.setFontSize(14);
            doc.text(title, 40, 40);
            
            doc.setFontSize(10);
            doc.text(`Unit: ${unitSel.value} | Date: ${fromEl.value} to ${toEl.value}`, 40, 55);
            doc.text(`Generated: ${new Date().toLocaleString()}`, 40, 70);

            doc.autoTable({
              head: [cols.map(c => c.header)],
              body: formatBody(rows).map(r => cols.map(c => r[c.dataKey])),
              startY: 80,
              theme: 'grid',
              styles: { 
                  fontSize: 7, // Reduced font to fit columns
                  cellPadding: 3,
                  overflow: 'linebreak' 
              },
              headStyles: { fillColor: [30, 58, 138], textColor: 255, fontStyle: 'bold' },
              columnStyles: {
                4: { halign: 'right' }, // Radio
                5: { halign: 'right' }, // Lab
                6: { halign: 'right' }, // Hosp
                7: { halign: 'right' }, // Disc
                8: { halign: 'right' }, // Net
                9: { halign: 'right' }, // Pharm
                10: { halign: 'right' }, // Ret
                11: { halign: 'right' }, // Rec
                12: { halign: 'right' }  // Due
              }
            });
          };

          let pageAdded = false;

          // 1. Generate Cash Sheet
          if (cashRows.length > 0) {
            drawSheet(`IPD Discharge Report - CASH (${cashRows.length})`, cashRows);
            pageAdded = true;
          }

          // 2. Generate Cashless Sheet
          if (cashlessRows.length > 0) {
            if (pageAdded) doc.addPage(); 
            drawSheet(`IPD Discharge Report - CASHLESS (${cashlessRows.length})`, cashlessRows);
          }

          if (cashRows.length === 0 && cashlessRows.length === 0) {
             alert('No Cash or Cashless data found in selection.');
             return;
          }

          doc.save(`IPD_Billing_Split_${unitSel.value}_${today}.pdf`);
        });
      }
      
    })();
  </script>
{% endblock %}

